# ─── Firebase ──────────────────────────────────────────────────────────────────
# Copy your real Firebase project config values here.
# Get them from: Firebase Console → Project Settings → Your apps → Web
#
# For development/demo, placeholder values allow the UI to load fully.
# Firebase auth/upload features require real credentials.

VITE_FIREBASE_API_KEY=AIzaSyDEMO-placeholder-replace-with-real-key
VITE_FIREBASE_AUTH_DOMAIN=famvault-demo.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=famvault-demo
VITE_FIREBASE_STORAGE_BUCKET=famvault-demo.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abc123def456

# ─── Google Cloud Vision API (optional) ────────────────────────────────────────
# For AI face detection + label tagging on uploads.
# Leave blank to skip AI analysis; uploads still work.
VITE_VISION_API_KEY=
