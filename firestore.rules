rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ──────────────────────────────────────────────────────

    function isAuthed() {
      return request.auth != null;
    }

    function isUser(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    function isFamilyMember(familyId) {
      return isAuthed() &&
             request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.memberUids;
    }

    function isFamilyAdmin(familyId) {
      return isAuthed() && familyId != null &&
             get(/databases/$(database)/documents/families/$(familyId)).data.adminUid == request.auth.uid;
    }

    // ─── Users ─────────────────────────────────────────────────────────────────

    match /users/{userId} {
      // Users can read their own doc, or docs of people in their same family
      allow read:   if isUser(userId) || (isAuthed() && isFamilyMember(resource.data.familyId));
      allow create: if isUser(userId);
      allow update: if isUser(userId) 
                    && (request.resource.data.role in ['member', 'admin', null] || !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
                    || isFamilyAdmin(resource.data.familyId);
      allow delete: if false; // Soft-delete only
    }

    // ─── Families ──────────────────────────────────────────────────────────────

    match /families/{familyId} {
      // Allow any authenticated user to read family metadata so they can query by inviteCode
      allow read: if isAuthed();

      // Anyone authenticated can create a family (they become admin via Cloud Function / client)
      allow create: if isAuthed()
                    && request.resource.data.adminUid == request.auth.uid
                    && request.resource.data.memberUids.hasAll([request.auth.uid])
                    && request.resource.data.storageLimitBytes <= 10737418240; // max 10GB

      // Only admin can update invite code, name, limits
      allow update: if isFamilyAdmin(familyId)
                    // Allow members to update storage usage when uploading/deleting
                    || (isFamilyMember(familyId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['storageUsedBytes']))
                    // Users can add OR remove THEMSELVES when joining/leaving
                    || (
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids']) &&
                         (
                           // Joining: Add self
                           (request.resource.data.memberUids.hasAll(resource.data.memberUids) && request.auth.uid in request.resource.data.memberUids) ||
                           // Leaving: Remove self
                           (resource.data.memberUids.hasAll(request.resource.data.memberUids) && !(request.auth.uid in request.resource.data.memberUids))
                         )
                       );

      allow delete: if isFamilyAdmin(familyId)
                    || (isFamilyMember(familyId) && (resource.data.adminUid == null || resource.data.adminUid == ""));
    }

    // ─── Media ─────────────────────────────────────────────────────────────────

    match /media/{mediaId} {
      // Any family member can read media in their family
      allow read: if isAuthed()
                  && isFamilyMember(resource.data.familyId);

      // Any family member can upload to their own family
      allow create: if isAuthed()
                    && isFamilyMember(request.resource.data.familyId)
                    && request.resource.data.uploaderUid == request.auth.uid
                    && request.resource.data.sizeBytes <= 524288000; // max 500MB per file

      // Only uploader or admin can update/delete
      allow update: if isAuthed()
                    && (resource.data.uploaderUid == request.auth.uid
                        || isFamilyAdmin(resource.data.familyId))
                    // Prevent changing familyId after creation
                    && request.resource.data.familyId == resource.data.familyId;

      allow delete: if isAuthed()
                    && (resource.data.uploaderUid == request.auth.uid
                        || isFamilyAdmin(resource.data.familyId));
    }

    // ─── Albums ────────────────────────────────────────────────────────────────

    match /families/{familyId}/albums/{albumId} {
      // Only members listed in allowedUids can read private albums
      allow read: if isAuthed()
                  && (isFamilyAdmin(familyId)
                      || request.auth.uid in resource.data.allowedUids);

      allow create: if isFamilyMember(familyId)
                    && request.resource.data.createdByUid == request.auth.uid;

      // Creator or admin can update
      allow update: if isAuthed()
                    && (resource.data.createdByUid == request.auth.uid
                        || isFamilyAdmin(familyId));

      allow delete: if isAuthed()
                    && (resource.data.createdByUid == request.auth.uid
                        || isFamilyAdmin(familyId));
    }

  }
}
